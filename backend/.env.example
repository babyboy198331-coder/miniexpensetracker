PORT=3000

# Your live frontend URL once deployed (GitHub Pages, etc). Leave unset for
# local dev to allow any origin.
FRONTEND_ORIGIN=https://yourname.github.io

# Access token: short-lived, sent with every protected request
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=15m

# Refresh token: long-lived, only used to mint new access tokens
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=7d
